# Copy to .env and fill in keys for cloud generation (XAI Grok Imagine + WaveSpeed).
# Without keys the bridge falls back to local Pillow / ffmpeg / CPU SD 1.5.

# Grok Imagine — images (flux-xai) and grok-imagine video
XAI_API_KEY=xai-xxxxxxxx
# Alternative name (same key):
# GROK_API_KEY=xai-xxxxxxxx

# WaveSpeed — wan-2.7, seedance, sora, veo, nano-banana, gpt-image-2, etc.
WAVESPEED_API_KEY=ws-xxxxxxxx